# URL do endpoint OTLP HTTP do seu Grafana Cloud
# Exemplo: https://otlp-gateway-prod-us-east-0.grafana.net/otlp
GRAFANA_OTLP_ENDPOINT=https://otlp-gateway-prod-us-east-0.grafana.net/otlp

# Credenciais do Grafana Cloud (Basic Auth em Base64)
# Formato: base64(InstanceID:APIToken)
# No Linux você pode gerar com: echo -n "123456:glc_sua_chave_api_aqui" | base64
GRAFANA_OTLP_AUTH_BASE64=base64_encoded_string_here
